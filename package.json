{
  "name": "geopathfinder",
  "version": "0.0.1",
  "description": "Geodesic-aware visibility graph implementation to support shortest path calculations on multi destination",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:Razielwar/geopathfinder.git"
  },
  "contributors": [
    "Xavier-Alexandre BILLARD <xabillard@gmail.com>"
  ],
  "engines": {
    "node": "^20.15.1",
    "yarn": "^4.3.1"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc --project tsconfig.test.json",
    "prepare": "GENERATE_SOURCEMAP=false yarn build",
    "bench": "node benchmark/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint --ext .ts --ignore-pattern '*.test.ts' src",
    "lint:fix": "eslint --fix --ext .ts --ignore-pattern '*.test.ts' src",
    "format": "prettier . --write",
    "clean:install": "rm package-lock.json && rm -r node_modules && yarn install && yarn audit fix",
    "semantic-release": "semantic-release",
    "clinic:doctor": "yarn run build:test && clinic doctor -- node ./dist-test/profile/VisibilityGraphProfiling.js",
    "clinic:flame": "yarn run build:test && clinic flame -- node ./dist-test/profile/VisibilityGraphProfiling.js",
    "clinic:heap": "yarn run build:test && clinic heapprofiler -- node ./dist-test/profile/VisibilityGraphProfiling.js",
    "postinstall": "husky"
  },
  "dependencies": {
    "@turf/turf": "^7.2.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/runtime": "^7.27.6",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@jest/globals": "^29.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^13.2.6",
    "@semantic-release/npm": "^12.0.1",
    "@swc/core": "^1.11.31",
    "@swc/jest": "^0.2.36",
    "@types/geojson": "^7946.0.16",
    "@types/lodash": "^4.17.17",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-istanbul": "^7.0.0",
    "benchmark": "^2.1.4",
    "clinic": "^13.0.0",
    "conventional-changelog-eslint": "^6.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.29.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.10",
    "nyc": "^17.1.0",
    "pinst": "^3.0.0",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.5",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "src/*.{js,ts}": "eslint --fix",
    "*.{js,ts,json}": "prettier --cache --write"
  }
}
